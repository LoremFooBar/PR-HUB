{
  "name": "pr-hub",
  "description": "Chrome extension that shows your open PRs, review requests, merged PRs, CI status, and base branches — with GitHub Primer theming and auto dark mode.",
  "private": true,
  "version": "0.6.4",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "mock": "vite --open /mock.html",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ct": "playwright test -c playwright-ct.config.ts"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.61.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.287",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  }
}
