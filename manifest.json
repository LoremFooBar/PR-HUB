{
  "manifest_version": 3,
  "name": "PR Hub",
  "version": "0.6.3",
  "description": "View your open PRs, review requests, merged PRs, CI status, and base branches with GitHub Primer theming.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PR Hub",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "sync-pr-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open/sync my open PRs into the \"My PRs\" tab group"
    }
  },
  "permissions": ["storage", "tabs", "tabGroups", "sidePanel", "alarms"]
}
